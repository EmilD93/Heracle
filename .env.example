# Base URL for the Heracle backend API.
# - In dev, '/api' works out of the box because vite.config.ts proxies
#   '/api' requests to http://localhost:8000 (see server.proxy).
# - For a deployed backend, set this to the full URL, e.g.:
#   VITE_API_URL=https://api.heracle.example.com/api
VITE_API_URL=/api
